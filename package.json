{
  "name": "veilarbvedtaksstottefs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite --mode demo",
    "build": "tsc && vite build --base=https://cdn.nav.no/obo/prod/veilarbvedtaksstottefs/dist",
    "build:dev": "tsc && vite build --base=https://cdn.nav.no/obo/dev/veilarbvedtaksstottefs/dist",
    "build:mock": "tsc && vite build --mode demo --base=/veilarbvedtaksstottefs/",
    "lint": "eslint src --max-warnings 0",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prettier:check": "prettier --check src --config .prettierrc.json",
    "prettier:write": "prettier --write src --config .prettierrc.json",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "dependencies": {
    "@navikt/aksel-icons": "8.10.5",
    "@navikt/arbeidssokerregisteret-utils": "2.1.0",
    "@navikt/ds-css": "8.10.5",
    "@navikt/ds-react": "8.10.5",
    "@navikt/fnrvalidator": "2.2.1",
    "@navikt/navspa": "7.5.0",
    "axios": "1.16.0",
    "classnames": "2.5.1",
    "constate": "3.3.3",
    "dayjs": "1.11.20",
    "dompurify": "3.4.2",
    "lodash.debounce": "4.0.8",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-pdf": "10.4.1",
    "react-router-dom": "7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@navikt/aksel-stylelint": "8.10.5",
    "@types/lodash.debounce": "4.0.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "less": "4.6.4",
    "lint-staged": "17.0.4",
    "msw": "2.14.6",
    "prettier": "3.8.3",
    "stylelint": "17.11.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  },
  "lint-staged": {
    "src/**/*.css": [
      "stylelint"
    ],
    "src/**/*.{json,less,md}": [
      "prettier --write"
    ],
    "src/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint"
    ]
  },
  "msw": {
    "workerDirectory": "public"
  },
  "stylelint": {
    "extends": "@navikt/aksel-stylelint/recommended"
  }
}
